# Copy this file to ".env" and fill in your own values.
# (The real .env is never committed to git.)

# --- Admin panel ---
# Login password fallback for /admin (you also have an email+password account).
ADMIN_PASSWORD=change-this-to-a-strong-password

# Secret used to sign login sessions. Generate a long random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-string

# --- Stripe (optional here) ---
# You can set the Stripe secret key in Admin -> Settings instead of here.
# If set, the admin-panel value overrides this one.
STRIPE_SECRET_KEY=

# --- Site URL (optional here) ---
# Public address used for Stripe redirects and affiliate links.
# You can also set this in Admin -> Settings. Leave empty for local testing.
DOMAIN=

# Port the server listens on (default 4242).
PORT=4242
